{
  "name": "github-pr-dash",
  "version": "1.0.0",
  "type": "module",
  "description": "Terminal dashboard for GitHub pull requests",
  "main": "dist/index.js",
  "bin": {
    "github-pr-dash": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --dts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@octokit/graphql": "^8.1.1",
    "chalk": "^5.3.0",
    "fullscreen-ink": "^0.1.0",
    "ink": "^5.1.0",
    "open": "^10.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "volta": {
    "node": "20.20.0",
    "npm": "10.8.2"
  }
}
